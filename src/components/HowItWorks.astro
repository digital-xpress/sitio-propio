---
const steps = [
  {
    number: '1',
    icon: 'design_services',
    title: 'Diseñamos',
    description: 'Lo creamos por ti basado en tu industria y objetivos. Diseño moderno y responsivo asegurado.',
  },
  {
    number: '2',
    icon: 'visibility',
    title: 'Te lo mostramos',
    description: 'Revisa tu sitio sin compromiso alguno. Si no te gusta, no pagas nada. Transparencia total.',
  },
  {
    number: '3',
    icon: 'rocket_launch',
    title: 'Activamos',
    description: 'Publicamos tu sitio en tu dominio. Planes desde USD $20/mes con todo incluido.',
  },
];
---

<section id="como-funciona" class="w-full py-16 bg-[#0F1629] border-t border-slate-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6 mb-12">
      <div class="max-w-2xl">
        <h2 class="text-blue-400 font-bold text-sm tracking-widest uppercase mb-2">Proceso Simplificado</h2>
        <h3 class="text-3xl md:text-4xl font-black text-white leading-tight">
          Tu sitio web en <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-violet-400">3 pasos simples</span>
        </h3>
        <p class="mt-4 text-text-muted text-lg">
          Olvídate de procesos largos y costosos. Hacemos que tener presencia digital sea fácil y accesible.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {steps.map((step) => (
        <div class="group relative p-8 rounded-2xl bg-card-dark border border-slate-800 shadow-lg hover:shadow-blue-900/10 hover:border-blue-500/30 transition-all duration-300">
          <div class="absolute top-0 right-0 p-4 opacity-5 text-6xl font-black text-white group-hover:text-blue-500 transition-colors select-none">
            {step.number}
          </div>
          <div class="w-14 h-14 rounded-xl bg-blue-500/10 text-blue-400 flex items-center justify-center mb-6 group-hover:bg-gradient-primary group-hover:text-white transition-colors">
            <span class="material-symbols-outlined text-3xl">{step.icon}</span>
          </div>
          <h4 class="text-xl font-bold text-white mb-2">{step.title}</h4>
          <p class="text-text-muted leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
